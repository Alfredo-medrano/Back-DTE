# ========================================
# MIDDLEWARE FACTURACIÓN ELECTRÓNICA
# Copia este archivo como .env y completa los valores
# ========================================
# ⚠️ NUNCA subir .env a GitHub

# Servidor
PORT=3000
NODE_ENV=development   # development | staging | production

# Docker Firmador (servicio de firma electrónica)
DOCKER_FIRMADOR_URL=http://localhost:8113

# Base de datos PostgreSQL (Neon o local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# API del Ministerio de Hacienda
MH_API_URL=https://apitest.dtes.mh.gob.sv
MH_AUTH_URL=https://apitest.dtes.mh.gob.sv/seguridad/auth

# Encriptación de credenciales MH (mínimo 32 caracteres, genera uno con:)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_SECRET_KEY=REEMPLAZAR_CON_KEY_SEGURA_DE_64_CHARS_HEX

# Panel de administración IAM — protege /admin con este header: X-Admin-Key
ADMIN_SECRET_KEY=REEMPLAZAR_CON_CLAVE_SEGURA

# ── ONLY FOR SETUP SCRIPT (npm run setup) ──────────────────────
# Datos del primer tenant/emisor a crear en el servidor
SETUP_TENANT_NOMBRE=Mi Empresa SaaS
SETUP_TENANT_EMAIL=admin@miempresa.com
SETUP_EMISOR_NIT=070000000
SETUP_EMISOR_NRC=0000001
SETUP_EMISOR_NOMBRE=NOMBRE COMPLETO CONTRIBUYENTE
SETUP_EMISOR_COD_ACTIVIDAD=62010
SETUP_EMISOR_DESC_ACTIVIDAD=ACTIVIDADES DE PROGRAMACION INFORMATICA
SETUP_EMISOR_COMPLEMENTO=DIRECCION FISCAL COMPLETA
SETUP_EMISOR_TELEFONO=22000000
SETUP_EMISOR_CORREO=facturacion@miempresa.com
SETUP_EMISOR_MH_CLAVE_API=TU_CLAVE_API_MH
SETUP_EMISOR_MH_CLAVE_PRIVADA=TU_CLAVE_PRIVADA_MH
SETUP_EMISOR_AMBIENTE=00   # 00=Pruebas, 01=Producción
