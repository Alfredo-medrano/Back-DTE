# ========================================
# MIDDLEWARE FACTURACIÓN ELECTRÓNICA
# Copia este archivo como .env y completa los valores
# ========================================
# ⚠️ NUNCA subir .env a GitHub

# Servidor
PORT=3000
NODE_ENV=development   # development | staging | production

# CORS — Orígenes permitidos para frontend (separados por coma)
# En producción, especificar dominios exactos
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Docker Firmador (servicio de firma electrónica)
DOCKER_FIRMADOR_URL=http://localhost:8113

# Base de datos PostgreSQL (Neon o local)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# API del Ministerio de Hacienda
MH_API_URL=https://apitest.dtes.mh.gob.sv
MH_AUTH_URL=https://apitest.dtes.mh.gob.sv/seguridad/auth

# Encriptación de credenciales MH
# CRYPTO_SECRET_KEY: clave maestra (mín. 32 chars). Genera con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRYPTO_SECRET_KEY=REEMPLAZAR_CON_KEY_SEGURA_DE_64_CHARS_HEX

# CRYPTO_SALT: salt para derivación scrypt de la clave AES-256-GCM (mín. 32 chars hex).
# Genera con: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# ⚠️ NO cambiar este valor después de tener emisores encriptados en BD.
#    Si cambia, los datos existentes no podrán desencriptarse.
CRYPTO_SALT=REEMPLAZAR_CON_SALT_ALEATORIO_DE_32_CHARS_HEX

# Panel de administración IAM — protege /admin con este header: X-Admin-Key
ADMIN_SECRET_KEY=REEMPLAZAR_CON_CLAVE_SEGURA

# JWT — Clave secreta para firma de tokens de sesión (mín. 32 chars)
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ⚠️ Si no se define, el servidor NO arrancará.
JWT_SECRET=REEMPLAZAR_CON_JWT_SECRET_SEGURO_DE_96_CHARS_HEX

# Redis (opcional) — Cache de tokens MH para multi-instancia
# Si no se define, se usa caché en memoria (no compartido entre workers PM2).
# REDIS_URL=redis://localhost:6379

# Notificaciones por correo electrónico (SMTP) — Opcional
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM="Factura DTE <notificaciones@miempresa.com>"

# Worker de Contingencia — Transmisión diferida de DTEs
# CONTINGENCY_BATCH_SIZE: DTEs a procesar por ciclo (default: 10)
# CONTINGENCY_INTERVAL_MS: Intervalo entre ciclos en ms (default: 120000 = 2min)
# CONTINGENCY_RUN_ONCE: Ejecutar un solo ciclo y salir (default: false)
# CONTINGENCY_MAX_RETRIES: Máx. reintentos por error de comunicación antes de abandonar (default: 20)
# CONTINGENCY_BATCH_SIZE=10
# CONTINGENCY_INTERVAL_MS=120000
# CONTINGENCY_RUN_ONCE=false
# CONTINGENCY_MAX_RETRIES=20

# URL del Frontend para enlaces de Representación Gráfica
FRONTEND_URL=http://localhost:3000

# ── ONLY FOR SETUP SCRIPT (npm run setup) ──────────────────────
# Datos del primer tenant/emisor a crear en el servidor
SETUP_TENANT_NOMBRE=Mi Empresa SaaS
SETUP_TENANT_EMAIL=admin@miempresa.com
SETUP_EMISOR_NIT=070000000
SETUP_EMISOR_NRC=0000001
SETUP_EMISOR_NOMBRE=NOMBRE COMPLETO CONTRIBUYENTE
SETUP_EMISOR_COD_ACTIVIDAD=62010
SETUP_EMISOR_DESC_ACTIVIDAD=ACTIVIDADES DE PROGRAMACION INFORMATICA
SETUP_EMISOR_COMPLEMENTO=DIRECCION FISCAL COMPLETA
SETUP_EMISOR_TELEFONO=22000000
SETUP_EMISOR_CORREO=facturacion@miempresa.com
SETUP_EMISOR_MH_CLAVE_API=TU_CLAVE_API_MH
SETUP_EMISOR_MH_CLAVE_PRIVADA=TU_CLAVE_PRIVADA_MH
SETUP_EMISOR_AMBIENTE=00   # 00=Pruebas, 01=Producción
