{
  "name": "fac-electronica",
  "version": "1.0.0",
  "description": "Middleware de Facturación Electrónica - El Salvador (DTE)",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "setup": "node scripts/setup.js",
    "test": "node tests/run_tests.js",
    "test:env": "node scripts/verificar_entorno.js",
    "test:all": "node scripts/ejecutar_suite_completa.js",
    "test:factura": "node tests/run_tests.js --tipo=01",
    "test:ccf": "node tests/run_tests.js --tipo=03",
    "test:credito": "node tests/run_tests.js --tipo=05",
    "test:excluido": "node tests/run_tests.js --tipo=14",
    "test:invalidacion": "node tests/test_invalidacion.js",
    "test:consulta": "node tests/test_consulta.js",
    "qa:seed": "node scripts/seed_qa.js",
    "qa:aislamiento": "node scripts/test_aislamiento.js",
    "qa:ratelimit": "node scripts/test_rate_limit.js",
    "qa:full": "node scripts/qa_full.js",
    "qa:saas": "node scripts/qa_full.js --only-saas",
    "worker:retries": "node src/modules/dte/workers/retry-worker.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:staging": "pm2 start ecosystem.config.js --env staging",
    "pm2:prod": "pm2 start ecosystem.config.js --env production",
    "pm2:restart": "pm2 reload ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status"
  },
  "keywords": [
    "facturacion",
    "electronica",
    "dte",
    "el-salvador",
    "hacienda"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.4",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "prisma": "^5.22.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
