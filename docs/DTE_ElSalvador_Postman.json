                        "description": "Retorna el mapa de todos los endpoints disponibles."
                    }
                }
            ]
        },
        {
            "name": "🔑 Admin IAM (X-Admin-Key)",
            "description": "Gestión de Tenants, Emisores y API Keys.\nRequiere header: X-Admin-Key con el valor de ADMIN_SECRET_KEY del .env\n\n⚠️ Flujo recomendado:\n  1. Crear Tenant\n  2. Copiar tenant_id → variable tenant_id\n  3. Crear Emisor para ese Tenant\n  4. Crear API Key → copiar la key a api_key\n  5. Usar api_key en las carpetas DTE",
            "item": [
                {
                    "name": "A1. Crear Tenant",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const r = pm.response.json();",
                                    "if (r.exito && r.datos && r.datos.id) {",
                                    "    pm.collectionVariables.set('tenant_id', r.datos.id);",
                                    "    console.log('✅ tenant_id guardado:', r.datos.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nombre\": \"Empresa Demo SA de CV\",\n  \"email\": \"admin@empresa-demo.com\",\n  \"telefono\": \"22001234\",\n  \"plan\": \"PROFESIONAL\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/admin/tenants",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants"
                            ]
                        },
                        "description": "Crea un nuevo cliente SaaS. El test script guarda {{tenant_id}} automáticamente."
                    }
                },
                {
                    "name": "A2. Listar Tenants",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/tenants",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants"
                            ]
                        },
                        "description": "Lista todos los tenants activos con conteos de emisores, API Keys y DTEs."
                    }
                },
                {
                    "name": "A3. Obtener Tenant por ID",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/tenants/{{tenant_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants",
                                "{{tenant_id}}"
                            ]
                        },
                        "description": "Retorna el tenant con sus emisores activos incluidos."
                    }
                },
                {
                    "name": "A4. Crear Emisor para Tenant",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const r = pm.response.json();",
                                    "if (r.exito && r.datos && r.datos.id) {",
                                    "    pm.collectionVariables.set('emisor_id', r.datos.id);",
                                    "    console.log('✅ emisor_id guardado:', r.datos.id);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nit\": \"070048272\",\n  \"nrc\": \"3799647\",\n  \"nombre\": \"ALFREDO EZEQUIEL MEDRANO MARTINEZ\",\n  \"codActividad\": \"62010\",\n  \"descActividad\": \"ACTIVIDADES DE PROGRAMACION INFORMATICA\",\n  \"complemento\": \"COLONIA CENTROAMERICA, SAN SALVADOR\",\n  \"telefono\": \"22001234\",\n  \"correo\": \"facturacion@empresa.com\",\n  \"mhClaveApi\": \"TU_CLAVE_API_MH\",\n  \"mhClavePrivada\": \"TU_CLAVE_PRIVADA_MH\",\n  \"ambiente\": \"00\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/admin/tenants/{{tenant_id}}/emisores",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants",
                                "{{tenant_id}}",
                                "emisores"
                            ]
                        },
                        "description": "Crea un emisor. Las credenciales MH se almacenan encriptadas (AES-256-CBC). El test script guarda {{emisor_id}} automáticamente."
                    }
                },
                {
                    "name": "A5. Crear API Key",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const r = pm.response.json();",
                                    "if (r.exito && r.datos && r.datos.apiKey) {",
                                    "    pm.collectionVariables.set('api_key', r.datos.apiKey);",
                                    "    console.log('✅ api_key guardada:', r.datos.apiKey);",
                                    "    console.log('⚠️ Guárdala — no se mostrará de nuevo');",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"nombre\": \"API Key Producción\",\n  \"ambiente\": \"00\",\n  \"permisos\": [\"dte:create\", \"dte:read\"],\n  \"rateLimit\": 100\n}",
                            "options": {
                                "raw": {
                                    "language": "json"
                                }
                            }
                        },
                        "url": {
                            "raw": "{{base_url}}/admin/tenants/{{tenant_id}}/api-keys",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants",
                                "{{tenant_id}}",
                                "api-keys"
                            ]
                        },
                        "description": "Genera una API Key. ⚠️ Solo se muestra UNA VEZ. El test script la guarda en {{api_key}} automáticamente."
                    }
                },
                {
                    "name": "A6. Listar API Keys del Tenant",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-Admin-Key",
                                "value": "{{admin_key}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/admin/tenants/{{tenant_id}}/api-keys",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants",
                                "{{tenant_id}}",
                                "api-keys"
                            ]
                        },
                        "description": "Lista API Keys sin mostrar la key real (solo metadata)."
                    }
                },
                {
                    "name": "A7. [SEGURIDAD] Sin Admin Key → debe dar 401",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/admin/tenants",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "admin",
                                "tenants"
                            ]
                        },
                        "description": "Sin X-Admin-Key → 401. Verifica que el panel no es público."
                    }
                }
            ]
        },
