{
    "info": {
        "_postman_id": "dte-el-salvador-v3",
        "name": "DTE El Salvador - API v3 (Completo)",
        "description": "Colección completa para el Middleware de Facturación Electrónica Multi-Tenant SaaS.\n\n📌 Variables a configurar:\n  - base_url: http://localhost:3000\n  - api_key: tu sk_test_xxx\n  - emisor_id: UUID del emisor\n  - admin_key: tu ADMIN_SECRET_KEY del .env\n  - codigo_generacion: UUID de un DTE PROCESADO (para anular)",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:3000",
            "type": "string"
        },
        {
            "key": "api_key",
            "value": "sk_test_REEMPLAZAR_CON_TU_API_KEY",
            "type": "string"
        },
        {
            "key": "emisor_id",
            "value": "REEMPLAZAR_CON_UUID_EMISOR",
            "type": "string"
        },
        {
            "key": "admin_key",
            "value": "REEMPLAZAR_CON_ADMIN_SECRET_KEY",
            "type": "string"
        },
        {
            "key": "tenant_id",
            "value": "REEMPLAZAR_DESPUES_DE_CREAR_TENANT",
            "type": "string"
        },
        {
            "key": "codigo_generacion",
            "value": "REEMPLAZAR_CON_UUID_DTE_PROCESADO",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "📋 Públicos",
            "item": [
                {
                    "name": "1. Health Check BD (Prisma)",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/health",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "health"
                            ]
                        },
                        "description": "Verifica conectividad con la base de datos usando prisma.$queryRaw SELECT 1. Devuelve 200 OK o 503 si la BD está caída."
                    }
                },
                {
                    "name": "2. Estado del Sistema (Docker + Hacienda)",
                    "request": {
                        "method": "GET",
