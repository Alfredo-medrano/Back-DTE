                            "raw": "{{base_url}}/api/dte/status",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "dte",
                                "status"
                            ]
                        },
                        "description": "Estado completo: servidor, Docker Firmador y API Hacienda."
                    }
                },
                {
                    "name": "3. Documento de Ejemplo (Anexo II)",
                    "request": {
                        "method": "GET",
                        "header": [],
